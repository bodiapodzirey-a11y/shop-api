{
  "info": {
    "name": "Shop API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get all products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products" }
        },
        {
          "name": "Get product by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/1" }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Нова клавіатура\",\n  \"price\": 1599,\n  \"stock\": 15,\n  \"category\": \"Електроніка\",\n  \"description\": \"Механічна клавіатура з підсвіткою\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1399,\n  \"stock\": 20\n}"
            },
            "url": "{{baseUrl}}/products/1"
          }
        },
        {
          "name": "Delete product",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/products/1" }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get all users",
          "request": { "method": "GET", "url": "{{baseUrl}}/users" }
        },
        {
          "name": "Get user by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/1" }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Марія Сидоренко\",\n  \"email\": \"maria@example.com\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new-email@example.com\"\n}"
            },
            "url": "{{baseUrl}}/users/1"
          }
        },
        {
          "name": "Delete user",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/users/1" }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get all orders",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders" }
        },
        {
          "name": "Get order by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders/1" }
        },
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"productId\": 2,\n  \"quantity\": 3\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Update order",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": "{{baseUrl}}/orders/1"
          }
        },
        {
          "name": "Delete order",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/orders/1" }
        }
      ]
    }
  ]
}
